# ── Database ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lardermind
DB_USERNAME=postgres
DB_PASSWORD=postgres
# use "disable" for local Docker Postgres; Railway/Supabase usually need "require"
DB_SSL_MODE=disable

# ── JWT ──
JWT_SECRET=change-me-to-a-long-random-string

# ── Cloudinary ──
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── DeepSeek LLM (OpenAI-compatible API) ──
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=4096

# ── Stripe (optional) ──
STRIPE_SECRET_KEY=

# ── CORS (comma-separated) ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost

# ── Frontend URL (OAuth redirects etc.) ──
FRONTEND_URL=http://localhost:5173

# ── Server ──
PORT=8080

# ── JVM (Docker / Railway) ──
# Dockerfile default: MaxRAMPercentage=65 (scales with container memory).
# Optional override, e.g. for a fixed heap on small plans:
# JAVA_OPTS=-Xms128m -Xmx384m -XX:+ExitOnOutOfMemoryError -Dfile.encoding=UTF-8 -Dsun.jnu.encoding=UTF-8

# ── Unsplash (optional) ──
UNSPLASH_ACCESS_KEY=
